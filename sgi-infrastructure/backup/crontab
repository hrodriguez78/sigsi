# SGI MongoDB Backup Cron Configuration
# Install: crontab -e  (add these lines)
# Or copy to /etc/cron.d/sgi-backup

# Daily backup at 2:00 AM (full dump + cleanup)
0 2 * * * root /opt/sgi/backup/backup.sh daily >> /var/log/sgi-backup.log 2>&1

# Weekly backup on Sundays at 3:00 AM (full + collections + cleanup)
0 3 * * 0 root /opt/sgi/backup/backup.sh weekly >> /var/log/sgi-backup.log 2>&1

# Monthly backup on 1st at 4:00 AM (full + collections + cleanup)
0 4 1 * * root /opt/sgi/backup/backup.sh monthly >> /var/log/sgi-backup.log 2>&1
